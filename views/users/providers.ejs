<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Providers</title>
</head>
<body>

<%- include("../partials/navbar") %>

<h1>Providers</h1>

<% providers.forEach((provider) => { %>

    <h2><%= provider.username %></h2>

    <!-- Customer can view this provider's availability -->
    <a href="/availability/provider/<%= provider._id %>">
        View Availability
    </a>

    <hr>

<% }) %>

</body>
</html>