<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Provider Appointments</title>
</head>

<body>

    <%- include("../partials/navbar") %>

    <h1>My Appointments</h1>

    <% appointments.forEach((appointment) => { %>

        <div>

            <h2>
                <%= appointment.service %>
            </h2>

            <p>
                Customer:
                <%= appointment.customer.username %>
            </p>

            <p>
                Date:
                <%= appointment.date.toDateString() %>
            </p>

            <p>
                Time:
                <%= appointment.startTime %>
                -
                <%= appointment.endTime %>
            </p>

            <p>
                Status:
                <%= appointment.status %>
            </p>


            <% if (appointment.status === "Pending") { %>

                <form
                    action="/appointments/<%= appointment._id %>/confirm"
                    method="POST"
                >

                    <button type="submit">
                        Confirm
                    </button>

                </form>


                <form
                    action="/appointments/<%= appointment._id %>/cancel"
                    method="POST"
                >

                    <button type="submit">
                        Cancel
                    </button>

                </form>

            <% } %>


            <% if (
                appointment.status === "Pending" ||
                appointment.status === "Confirmed"
            ) { %>

                <a href="/appointments/<%= appointment._id %>/reschedule">

                    Reschedule

                </a>

            <% } %>


            <form
                action="/appointments/<%= appointment._id %>/delete"
                method="POST"
            >

                <button type="submit">
                    Delete
                </button>

            </form>

            <hr>

        </div>

    <% }) %>

</body>

</html>