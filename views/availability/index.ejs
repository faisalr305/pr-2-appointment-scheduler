<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Availability</title>
</head>
<body>

<%- include("../partials/navbar") %>

<h1>Provider Availability</h1>

<% if (availability.length === 0) { %>

    <p>No availability found.</p>

<% } else { %>

    <% availability.forEach((slot) => { %>

        <div>

            <h3><%= slot.day %></h3>

            <p>
                Available Slots:
                <%= slot.availableSlots.join(", ") %>
            </p>

        </div>

    <% }) %>

<% } %>

</body>
</html>