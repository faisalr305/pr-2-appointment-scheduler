<!DOCTYPE html>
<html>
<head>
    <title>Add Availability</title>
</head>
<body>

<%- include("../partials/navbar") %>

<h1>Add Availability</h1>

<form action="/availability" method="POST">

<label>Date</label>

<input
type="date"
name="date"
required>

<br><br>

<label>Available Time Slots</label>

<input
type="text"
name="slots"
placeholder="09:00,10:00,11:00,14:00"
required>

<br><br>

<button type="submit">

Save Availability

</button>

</form>

</body>
</html>