<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Provider Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/appointments/provider-dashboard">
                Provider Dashboard
            </a>

            <div class="d-flex gap-2">
                <a href="/" class="btn btn-outline-light">Home</a>
                <a href="/availability/new" class="btn btn-success">Create Availability</a>
 <a href="/auth/sign-out" class="btn btn-danger">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1>Provider Dashboard</h1>
                <p class="text-muted">Manage your appointments.</p>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>Appointments</h5>
                        <h2><%= appointments.length %></h2>
                        <a href="#appointments" class="btn btn-primary">
                            View Appointments
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div id="appointments">
            <h2 class="mb-4">My Appointments</h2>

            <% if (appointments.length === 0) { %>
                <div class="alert alert-info">
                    You currently have no appointments.
                </div>
            <% } %>

            <% appointments.forEach(appointment => { %>
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4>
                                    <%= appointment.customer ? appointment.customer.username : "Unknown Customer" %>
                                </h4>

                                <p class="mb-1">
                                    <strong>Service:</strong>
                                    <%= appointment.service || "N/A" %>
                                </p>

                                <p class="mb-1">
                                    <strong>Date:</strong>
                                    <%= appointment.date ? new Date(appointment.date).toDateString() : "N/A" %>
                                </p>

                                <p class="mb-1">
                                    <strong>Time:</strong>
                                    <%= appointment.startTime || "N/A" %>
                                </p>

                                <% if (appointment.notes) { %>
                                    <p class="mb-1">
                                        <strong>Notes:</strong>
                                        <%= appointment.notes %>
                                    </p>
                                <% } %>
                            </div>

                            <span class="badge bg-secondary">
                                <%= appointment.status %>
                            </span>
                        </div>

                        <hr>

                        <div class="d-flex gap-2 flex-wrap">
                            <% if (appointment.status === "pending") { %>
                                <form action="/appointments/<%= appointment._id %>/accept?_method=PUT" method="POST">
                                    <button type="submit" class="btn btn-success">
                                        Accept
                                    </button>
                                </form>

                                <form action="/appointments/<%= appointment._id %>/cancel?_method=PUT" method="POST">
                                    <button type="submit" class="btn btn-warning">
                                        Cancel
                                    </button>
                                </form>
                            <% } %>

                            <% if (appointment.status === "confirmed") { %>
                                <form action="/appointments/<%= appointment._id %>/complete?_method=PUT" method="POST">
                                    <button type="submit" class="btn btn-primary">
                                        Complete
                                    </button>
                                </form>

                                <form action="/appointments/<%= appointment._id %>/cancel?_method=PUT" method="POST">
                                    <button type="submit" class="btn btn-warning">
                                        Cancel
                                    </button>
                                </form>
                            <% } %>

                            <form action="/appointments/<%= appointment._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn btn-danger">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
 <% }) %>
    </div>
    </div>
</body>
</html>