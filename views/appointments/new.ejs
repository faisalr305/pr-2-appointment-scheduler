<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>New Appointment</title>
</head>

<body>

    <%- include("../partials/navbar") %>

    <h1>Create Appointment</h1>


    <form action="/appointments" method="POST">

        <label>Title:</label>
        <input 
            type="text" 
            name="title"
            required
        >

        <br>


        <label>Service:</label>
        <input 
            type="text" 
            name="service"
            required
        >

        <br>


        <label>Date:</label>
        <input 
            type="date" 
            name="date"
            required
        >

        <br>
        <label>Start Time:</label>
        <input 
            type="time" 
            name="startTime"
            required
        >

        <br>
        <label>End Time:</label>
        <input 
            type="time" 
            name="endTime"
            required
        >
             
        <br>
        <label>Notes:</label>
        <textarea name="notes"></textarea>

        <br>
<label>Provider:</label>
<input 
    type="text"
    name="provider"
    required
><br>

        <button type="submit">
            Create Appointment
        </button>
    </form>


</body>
</html>