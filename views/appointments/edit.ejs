<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Appointment</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            color: #333;
        }

        .edit-container {
            width: 90%;
            max-width: 650px;
            margin: 40px auto;
            background-color: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #222;
        }

        form {
            display: flex;
            flex-direction: column;
        }

        label {
            margin-top: 15px;
            margin-bottom: 6px;
            font-weight: bold;
        }

        input,
        textarea {
            width: 100%;
            padding: 11px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 15px;
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #555;
        }

        textarea {
            min-height: 100px;
            resize: vertical;
        }

        button {
            margin-top: 25px;
            padding: 12px;
            border: none;
            border-radius: 5px;
            background-color: #333;
            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background-color: #555;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #333;
            text-decoration: none;
        }

        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

<%- include("../partials/navbar") %>

<div class="edit-container">

    <h1>Edit Appointment</h1>

    <form action="/appointments/<%= appointment._id %>?_method=PUT" method="POST">

        <label>Title</label>
        <input
            type="text"
            name="title"
            value="<%= appointment.title || "" %>"
        >

        <label>Service</label>
        <input
            type="text"
            name="service"
            value="<%= appointment.service || "" %>"
        >

        <label>Date</label>
        <input
            type="date"
            name="date"
            value="<%= appointment.date ? new Date(appointment.date).toISOString().split('T')[0] : '' %>"
        >

        <label>Start Time</label>
        <input
            type="time"
            name="startTime"
            value="<%= appointment.startTime || "" %>"
        >

        <label>End Time</label>
        <input
            type="time"
            name="endTime"
            value="<%= appointment.endTime || "" %>"
        >

        <label>Provider</label>
        <input
            type="text"
            name="provider"
            value="<%= appointment.provider ? appointment.provider.username : "" %>"
            readonly
        >

        <label>Notes</label>

        <textarea name="notes"><%= appointment.notes || "" %></textarea>

        <button type="submit">
            Update Appointment
        </button>

    </form>

    <a
        href="/appointments/<%= appointment._id %>"
        class="back-link"
    >
        Back to Appointment
    </a>

</div>

</body>
</html>