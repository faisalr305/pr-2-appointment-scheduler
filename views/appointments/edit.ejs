<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Appointment</title>
</head>
<body>

<%- include("../partials/navbar") %>

<h1>Edit Appointment</h1>

<form action="/appointments/<%= appointment._id %>?_method=PUT" method="POST">

    <label>Title</label>
    <input type="text" name="title" value="<%= appointment.title %>">

    <br>

    <label>Service</label>
    <input type="text" name="service" value="<%= appointment.service %>">

    <br>

    <label>Date</label>
    <input type="date" name="date" value="<%= appointment.date %>">

    <br>

    <label>Start Time</label>
    <input type="time" name="startTime" value="<%= appointment.startTime %>">

    <br>

    <label>End Time</label>
    <input type="time" name="endTime" value="<%= appointment.endTime %>">

    <br>

    <label>Provider</label>
    <input type="text" name="provider" value="<%= appointment.provider %>">

    <br>

    <label>Notes</label>
    <textarea name="notes"><%= appointment.notes %></textarea>

    <br>

    <button type="submit">Update Appointment</button>

</form>

</body>
</html>