<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Appointments</title>
</head>

<body>

    <%- include("../partials/navbar") %>

        <h1>My Appointments</h1>

        <a href="/appointments/new">
            Create New Appointment
        </a>
        <% appointments.forEach((appointment)=> { %>

            <div>

                <h2>
                    <%= appointment.title %>
                </h2>

                <p>
                    Service:
            <%= appointment.service %>
                </p>

                <p>
                    Date:
                    <%= appointment.date %>
                </p>

                <p>
                    Time:
                    <%= appointment.startTime %>
                        -
                        <%= appointment.endTime %>
                </p>

                <a href="/appointments/<%= appointment._id %>">
                    View
                </a>

            </div>

            <% }) %>


</body>

</html>